{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    { "source": "/blog/:path*", "destination": "/guides/:path*", "permanent": true },
    { "source": "/submit-listing", "destination": "/get-listed", "permanent": true },
    { "source": "/add-listing", "destination": "/get-listed", "permanent": true },
    { "source": "/listing-category/:path*", "destination": "/industries/:path*", "permanent": true }
  ]
}
